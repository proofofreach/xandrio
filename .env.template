# Xandrio Environment Configuration Template
# Copy this file to .env and fill in your values

# Optional: Anna's Archive key. Leave blank to use the configured primary path.
# ANNAS_SECRET_KEY=
# ANNAS_BASE_URL=https://annas-archive.gl
# Optional explicit CLI path for service managers with a restricted PATH.
# ANNAS_MCP_BIN=/home/xandrio/.local/bin/annas-mcp
# The default origin is always allowed. List any additional operator-approved
# public HTTPS mirror origins here before selecting one in Settings.
# ANNAS_ALLOWED_ORIGINS=https://annas-archive.gl
# Optional browser search is disabled by default. Set this only after reviewing
# the provider's current terms and confirming automated access is permitted.
# ANNAS_BROWSER_SEARCH_MODE=permitted
# Optional egress proxy for shadow-library acquisition only (Anna's Archive
# downloads and all Z-Library requests). Point this at an HTTP CONNECT proxy to
# route just that traffic through a separate network path (for example a proxy
# bound inside a VPN network namespace); all other providers and outbound
# requests are unaffected. Leave unset to send every request directly.
# BOOK_PROXY_URL=http://10.200.0.2:8888
# Anna searches use a 20s provider budget normally and 75s when the browser
# fallback is permitted. Override within 15000-120000 milliseconds if needed.
# ANNAS_SEARCH_TIMEOUT_MS=75000

# Search groups clear cross-source aliases conservatively by default. Use
# `exact` temporarily to disable typo and publisher/imprint alias resolution
# while retaining exact-title and trusted Open Library grouping.
# SEARCH_WORK_GROUPING_MODE=conservative
# Emit local structured work-resolution decisions. No telemetry is sent.
# SEARCH_GROUP_DEBUG=0

# Optional operator-configured OPDS catalog. Basic auth is sent only when a
# username is configured; set OPDS_REQUIRE_AUTH=true to require credentials.
# OPDS_FEED_URL=https://catalog.example.org/opds
# OPDS_LABEL=Personal OPDS
# OPDS_USER=
# OPDS_PASSWORD=
# OPDS_REQUIRE_AUTH=false

# Standard Ebooks uses its public OPDS feed by default. Override only for a
# mirror or authenticated deployment.
# STANDARD_EBOOKS_OPDS_URL=https://standardebooks.org/feeds/opds
# STANDARD_EBOOKS_OPDS_USER=
# STANDARD_EBOOKS_OPDS_PASSWORD=

# Access token for private-instance mode (recommended outside a trusted LAN).
# When set, every /api route including library metadata and audio requires
# authentication. API clients may use Authorization: Bearer <token>.
# When unset AND no accounts exist, trusted-LAN mode is active: anyone who
# can reach the server can access its library, audio, credentials, and
# settings.
#
# Multi-user accounts: create username/password accounts with
#   node --env-file-if-exists=.env scripts/manage-accounts.js add <username> [--admin]
# Once at least one account exists, browser login switches to
# username/password (the token no longer works as a browser credential) and
# the token remains valid only as an admin-equivalent Bearer credential for
# scripts and monitoring. See scripts/manage-accounts.js for passwd/list/
# disable/enable and the --profile / --absorb-default migration flags.
# XANDRIO_TOKEN=choose_a_long_random_string
# Session lifetime after web login (1–2160 hours; default 720 / 30 days).
# XANDRIO_SESSION_TTL_HOURS=720

# Server Configuration
PORT=8181
HOST=127.0.0.1
NODE_ENV=production

# HTTPS (optional)
# Set both files to serve TLS directly from Node. Android must trust the issuing CA.
# HTTPS_KEY_FILE=/path/to/privkey.pem
# HTTPS_CERT_FILE=/path/to/fullchain.pem

# Tailscale Serve HTTPS proxy (optional; enabled by npm start/dev by default)
# TAILSCALE_SERVE_AUTO=true
# TAILSCALE_BIN=/Applications/Tailscale.app/Contents/MacOS/Tailscale
# TAILSCALE_SERVE_HTTPS_PORT=443
# TAILSCALE_SERVE_TARGET=http://127.0.0.1:8181

# Paths (optional - defaults shown)
# CACHE_DIR=/path/to/cache
# DATA_DIR=/path/to/data

# PDF extraction (optional)
# Poppler is used automatically when available. Enable OCR only if scanned PDFs
# should be converted during import; OCR is slower and CPU-heavy.
# XANDRIO_PDF_OCR=false
# XANDRIO_PDF_OCR_MODE=redo-ocr
# XANDRIO_PDF_OCR_LANG=eng
# XANDRIO_PDF_OCR_JOBS=4
# XANDRIO_PDF_OCR_TIMEOUT_MS=1200000

# TTS Configuration (optional - defaults shown)
# XANDRIO_DEFAULT_VOICE=en-US-AndrewMultilingualNeural
# Set false to generate only when playback requests audio instead of warming
# the first chapters immediately after import.
# XANDRIO_PREGENERATE_ON_IMPORT=true
# KOKORO_TTS_URL=http://127.0.0.1:8766
# KOKORO_TTS_AUDIO_FORMAT=wav
# KOKORO_MASTERING_GAIN_DB=9.5
# KOKORO_PYTHON=kokoro-venv/bin/python
# KOKORO_AUTO_START=true
# KOKORO_CHUNK_SIZE=600
# KOKORO_PRELOAD_LANGS=a,b
# KOKORO_PRELOAD_VOICES=af_heart,af_bella,am_adam,am_michael,bm_george,bm_lewis
# KOKORO_TORCH_THREADS=8
# CHATTERBOX_TTS_URL=http://127.0.0.1:8767
# CHATTERBOX_TTS_AUDIO_FORMAT=wav
# CHATTERBOX_MASTERING_GAIN_DB=2.5
# EDGE_MASTERING_GAIN_DB=3
# CHATTERBOX_PYTHON=chatterbox-venv/bin/python
# CHATTERBOX_AUTO_START=true
# CHATTERBOX_RESTART_DELAY_MS=1000
# CHATTERBOX_RESTART_MAX_DELAY_MS=30000
# CHATTERBOX_STABLE_MS=30000
# CHATTERBOX_ENGINE=
# Empty uses MLX on macOS and PyTorch elsewhere. Override with mlx, pytorch,
# v3 for Multilingual V3 PyTorch, or v3-mlx for a converted V3 MLX model.
# CHATTERBOX_MLX_MODEL=models/chatterbox-v3-mlx-8bit
# CHATTERBOX_DEVICE=mps
# CHATTERBOX_VOICE_DIR=data/voice-references
# CHATTERBOX_PROFILE=balanced
# CHATTERBOX_CHUNK_SIZE=280
# CHATTERBOX_CONCURRENCY=1
# CHATTERBOX_TIMEOUT_MS=180000
# CHATTERBOX_REF_VERSION=brick-scott-20260707
# Apple Silicon V3 starting points (measure on the target machine):
# HF_HUB_DISABLE_XET=1
# PYTORCH_ENABLE_MPS_FALLBACK=1
# PYTORCH_MPS_HIGH_WATERMARK_RATIO=1.0
# PYTORCH_MPS_LOW_WATERMARK_RATIO=0.9
# PYTORCH_MPS_PREFER_METAL=1

# Security Configuration
# Cross-origin browser access is disabled by default; same-origin self-hosting,
# Tailscale, and reverse-proxy deployments do not need this setting. To allow
# a separate web origin, list exact comma-separated origins (never use *).
# CORS_ORIGIN=https://reader.example.com,https://xandrio.local
# Trust this many proxy hops before honoring X-Forwarded-Proto (needed for
# Secure session cookies behind a reverse proxy). Keep unset for direct Node.
# XANDRIO_TRUST_PROXY=1
# RATE_LIMIT_WINDOW=60000
# RATE_LIMIT_MAX=60
# Concurrent expensive requests are bounded per Node process. Raise these only
# after measuring CPU, memory, provider quotas, and storage throughput.
# XANDRIO_CONCURRENCY_AUTH=8
# XANDRIO_CONCURRENCY_SEARCH=4
# XANDRIO_CONCURRENCY_DOWNLOAD=2
# XANDRIO_CONCURRENCY_UPLOAD=2
# XANDRIO_CONCURRENCY_METADATA=2
# XANDRIO_CONCURRENCY_TTS=8
# XANDRIO_CONCURRENCY_VOICE=1

# Android Trusted Web Activity (optional)
# Required only if wrapping the HTTPS site in an Android TWA.
# TWA_PACKAGE_NAME=com.example.xandrio
# TWA_SHA256_CERT_FINGERPRINTS=AA:BB:CC:DD:...
